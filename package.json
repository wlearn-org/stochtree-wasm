{
  "name": "@wlearn/stochtree",
  "version": "0.1.0",
  "description": "StochTree BART (Bayesian Additive Regression Trees) compiled to WebAssembly",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "wasm/",
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node test/test.js",
    "build": "bash scripts/build-wasm.sh",
    "verify": "bash scripts/verify-exports.sh",
    "build:browser": "bash scripts/build-browser.sh",
    "prepack": "node scripts/prepack.js"
  },
  "dependencies": {
    "@wlearn/core": "0.1.0",
    "@wlearn/types": "0.1.0"
  },
  "keywords": [
    "bart",
    "bayesian-additive-regression-trees",
    "stochtree",
    "machine-learning",
    "wasm",
    "webassembly",
    "wlearn"
  ],
  "author": "Anton Zemlyansky",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlearn-org/stochtree-wasm.git"
  },
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.3",
    "playwright": "^1.58.2"
  }
}
